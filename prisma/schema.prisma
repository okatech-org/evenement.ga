// EventFlow — Prisma Schema
// PostgreSQL database schema for the event management platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────

enum Role {
  ORGANIZER
  CO_ORGANIZER
  GUEST_PREVIEW
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  ESSENTIEL
  PREMIUM
  ENTREPRISE
}

enum EventType {
  MARIAGE
  ANNIVERSAIRE
  DEUIL
  BAPTEME
  CONFERENCE
  PRIVE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Visibility {
  PUBLIC
  SEMI_PRIVATE
  PRIVATE
  PASSWORD
}

enum GuestStatus {
  INVITED
  SEEN
  CONFIRMED
  DECLINED
  ABSENT
}

enum ModuleType {
  MOD_INVITE
  MOD_RSVP
  MOD_MENU
  MOD_QR
  MOD_LOGISTIQUE
  MOD_CHAT
  MOD_PROGRAMME
  MOD_GALERIE
  MOD_DASHBOARD
}

enum ScanStatus {
  VALID
  ALREADY_SCANNED
  INVALID
  EXPIRED
}

enum MessageType {
  TEXT
  IMAGE
  REACTION
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ControllerPermission {
  VERIFY // Read-only: can verify status but not record scans
  SCAN   // Full: can verify AND record entry scans
}

// ─── Models ─────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  password        String?
  phone           String?   @unique
  image           String?
  role            Role      @default(ORGANIZER)
  plan            Plan      @default(FREE)
  emailVerified   DateTime?
  isDemoAccount   Boolean   @default(false)
  demoAccountType String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  events        Event[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  qrScans       QRScan[]       @relation("ScannedBy")

  @@map("users")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@map("otp_codes")
}

model Event {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  type        EventType
  date        DateTime
  endDate     DateTime?
  location    String?
  description String?     @db.Text
  status      EventStatus @default(DRAFT)
  visibility  Visibility  @default(SEMI_PRIVATE)
  password    String?
  maxGuests   Int?
  coverImage  String?
  coverVideo  String?
  userId      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           EventTheme?
  modules         EventModule[]
  guests          Guest[]
  chatMessages    ChatMessage[]
  qrScans         QRScan[]
  controllerLinks ControllerLink[]

  @@index([userId])
  @@index([slug])
  @@map("events")
}

model EventTheme {
  id               String  @id @default(cuid())
  eventId          String  @unique
  preset           String  @default("mariage")
  entryEffect      String  @default("fade_white")
  ambientEffect    String?
  ambientIntensity Float   @default(0.6)
  scrollReveal     String  @default("fade_up")
  cursorEffect     String?
  soundEnabled     Boolean @default(false)
  soundUrl         String?
  colorPrimary     String  @default("#8B5A6A")
  colorSecondary   String  @default("#C48B90")
  colorAccent      String  @default("#C9A96E")
  colorBackground  String  @default("#FFFDF9")
  colorText        String  @default("#3D2428")
  colorSurface     String  @default("#FFFFFF")
  colorMuted       String  @default("#9B8A8E")
  colorBorder      String  @default("#E8DDD5")
  fontDisplay      String  @default("Cormorant Garamond")
  fontBody         String  @default("Montserrat")
  fontSizeTitle    String  @default("2xl")
  fontSizeBody     String  @default("base")
  letterSpacing    String  @default("normal")
  lineHeight       String  @default("normal")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_themes")
}

model EventModule {
  id         String     @id @default(cuid())
  eventId    String
  type       ModuleType
  active     Boolean    @default(true)
  order      Int        @default(0)
  configJson Json       @default("{}")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
  @@index([eventId])
  @@map("event_modules")
}

model Guest {
  id          String      @id @default(cuid())
  eventId     String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  group       String?
  status      GuestStatus @default(INVITED)
  inviteToken String?     @unique
  qrToken     String?     @unique
  qrExpiresAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvp    RSVP?
  qrScans QRScan[]

  @@index([eventId])
  @@index([email])
  @@map("guests")
}

model RSVP {
  id            String   @id @default(cuid())
  guestId       String   @unique
  presence      Boolean
  adultCount    Int      @default(1)
  childrenCount Int      @default(0)
  menuChoice    String?
  allergies     String[]
  message       String?  @db.Text
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("rsvps")
}

model QRScan {
  id               String     @id @default(cuid())
  guestId          String
  eventId          String
  scannedAt        DateTime   @default(now())
  scannedBy        String?
  controllerLinkId String?
  status           ScanStatus

  guest          Guest           @relation(fields: [guestId], references: [id], onDelete: Cascade)
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scanner        User?           @relation("ScannedBy", fields: [scannedBy], references: [id])
  controllerLink ControllerLink? @relation(fields: [controllerLinkId], references: [id], onDelete: SetNull)

  @@index([guestId])
  @@index([eventId])
  @@index([controllerLinkId])
  @@map("qr_scans")
}

model ControllerLink {
  id         String               @id @default(cuid())
  eventId    String
  token      String               @unique
  label      String               // "Sécurité entrée", "Hôtesse VIP", etc.
  permission ControllerPermission @default(VERIFY)
  isActive   Boolean              @default(true)
  expiresAt  DateTime?
  createdAt  DateTime             @default(now())
  lastUsedAt DateTime?

  event Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scans QRScan[]

  @@index([eventId])
  @@index([token])
  @@map("controller_links")
}

model ChatMessage {
  id         String      @id @default(cuid())
  eventId    String
  userId     String?
  channel    String      @default("general")
  content    String      @db.Text
  type       MessageType @default(TEXT)
  senderName String      @default("Anonyme")
  senderRole String      @default("GUEST") // GUEST | ORGANIZER
  replyToId  String?
  reactions  Json        @default("{}")
  createdAt  DateTime    @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId, channel])
  @@map("chat_messages")
}

model Notification {
  id      String   @id @default(cuid())
  userId  String
  type    String
  content String   @db.Text
  read    Boolean  @default(false)
  sentAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ─── System Models (Super Admin) ────────────────────────────

model SystemLog {
  id         String   @id @default(cuid())
  level      LogLevel
  category   String
  action     String
  actorId    String?
  targetId   String?
  targetType String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([level, category, createdAt])
  @@index([actorId])
  @@map("system_logs")
}

model GlobalConfig {
  id                 String   @id @default("global")
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  newRegistrations   Boolean  @default(true)
  demoEnabled        Boolean  @default(true)
  maxEventsPerUser   Json     @default("{\"FREE\":1,\"ESSENTIEL\":3,\"PREMIUM\":-1,\"ENTREPRISE\":-1}")
  maxGuestsPerEvent  Json     @default("{\"FREE\":50,\"ESSENTIEL\":200,\"PREMIUM\":1000,\"ENTREPRISE\":-1}")
  featureFlags       Json     @default("{\"ENABLE_QR_SCAN\":true,\"ENABLE_CHAT\":true,\"ENABLE_GALLERY_UPLOAD\":true,\"ENABLE_DEMO_AUTO_LOGIN\":true,\"ENABLE_AI_SUGGESTIONS\":false,\"ENABLE_STRIPE\":false,\"MAINTENANCE_MODE\":false}")
  updatedAt          DateTime @updatedAt
  updatedBy          String?

  @@map("global_config")
}

model AbuseReport {
  id          String       @id @default(cuid())
  reportedBy  String
  targetId    String
  targetType  String
  reason      String
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([targetId])
  @@map("abuse_reports")
}
