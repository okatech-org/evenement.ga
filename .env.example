# ─── Database ─────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/eventflow?schema=public"

# ─── NextAuth ─────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3004"

# ─── Application ──────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3004"
NEXT_PUBLIC_APP_NAME="EventFlow"

# ─── JWT (QR Codes) ──────────────────────────
JWT_SECRET="your-jwt-secret-for-qr-codes-generate-with-openssl-rand-base64-32"

# ─── Email (Resend) ──────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="EventFlow <noreply@yourdomain.com>"

# ─── Storage (AWS S3 / Cloudflare R2) ────────
AWS_S3_BUCKET="eventflow-uploads"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="eu-west-3"

# ─── Redis (Upstash — rate limiting & locks) ─
UPSTASH_REDIS_URL="your-upstash-redis-url"
UPSTASH_REDIS_TOKEN="your-upstash-redis-token"

# ─── Pusher (Chat temps réel) ────────────────
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"

# ─── Stripe (Facturation — v2.0) ─────────────
STRIPE_SECRET_KEY="sk_test_your_stripe_secret"
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_test_your_stripe_public"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"
# Webhook endpoint à configurer dans le dashboard Stripe :
#   Dev  : stripe listen --forward-to http://localhost:3004/api/checkout/webhook
#   Prod : https://<your-domain>/api/checkout/webhook

# ─── Monitoring (Sentry) ─────────────────────
SENTRY_DSN="https://your-sentry-dsn"

# ─── OAuth Providers ─────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# ─── Apple Sign-In ────────────────────────────
APPLE_CLIENT_ID="your-apple-service-id"
APPLE_CLIENT_SECRET="your-apple-client-secret-jwt"
APPLE_TEAM_ID="your-apple-team-id"
APPLE_KEY_ID="your-apple-key-id"

# ─── Convex (Real-time) ─────────────────────
NEXT_PUBLIC_CONVEX_URL="https://your-project.convex.cloud"

# ─── WhatsApp Business API ───────────────────
WHATSAPP_API_KEY="your-whatsapp-business-api-key"
